---
import Navbar from "../components/Navbar.astro";
import Footer from "../components/Footer.astro";
---

<html lang="en">
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="viewport" content="width=device-width" />
		<meta name="generator" content={Astro.generator} />
		<title>Generador de Portadas 1920x1080</title>
		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
		<link
			href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=Manrope:wght@400;600;700;800&display=swap"
			rel="stylesheet"
		/>
		<style>
			:root {
				--paper: #fcf8ed;
				--ink: #11202f;
				--accent: #df5b1c;
				--accent-dark: #a74114;
				--panel: rgba(255, 255, 255, 0.9);
				--shadow: 0 14px 35px rgba(9, 25, 36, 0.22);
			}

			* {
				box-sizing: border-box;
			}

			body {
				margin: 0;
				font-family: "Manrope", "Segoe UI", sans-serif;
				color: var(--ink);
				background:
					radial-gradient(circle at 8% 15%, #fff2cb 0%, rgba(255, 242, 203, 0) 35%),
					radial-gradient(circle at 95% 10%, #ffd6c2 0%, rgba(255, 214, 194, 0) 38%),
					linear-gradient(160deg, #f9efe3, #f6dfcb);
				min-height: 100vh;
			}

			.wrapper {
				width: min(1150px, 92vw);
				margin: 2.2rem auto;
				display: grid;
				gap: 1.2rem;
			}

			.title {
				margin: 0;
				font-family: "Bebas Neue", Impact, sans-serif;
				font-size: clamp(2.1rem, 8vw, 4rem);
				letter-spacing: 0.05em;
				line-height: 0.92;
			}

			.subtitle {
				margin: 0;
				opacity: 0.8;
				font-size: 0.97rem;
			}

			.controls {
				display: grid;
				grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
				gap: 0.85rem;
				background: var(--panel);
				border-radius: 18px;
				padding: 1rem;
				box-shadow: var(--shadow);
				backdrop-filter: blur(4px);
			}

			.field {
				display: grid;
				gap: 0.45rem;
			}

			.drop-zone {
				border: 2px dashed rgba(17, 32, 47, 0.28);
				border-radius: 12px;
				padding: 0.55rem;
				background: rgba(255, 255, 255, 0.66);
				transition: border-color 120ms ease, background 120ms ease;
			}

			.drop-zone.drag-over {
				border-color: var(--accent);
				background: rgba(255, 240, 232, 0.92);
			}

			.drop-zone small {
				font-size: 0.78rem;
				opacity: 0.8;
			}

			label {
				font-size: 0.85rem;
				font-weight: 700;
				letter-spacing: 0.03em;
				text-transform: uppercase;
			}

			input[type="file"],
			input[type="color"],
			select {
				width: 100%;
				border: 1px solid #c8baa9;
				border-radius: 10px;
				padding: 0.55rem 0.6rem;
				background: #fffdf9;
				font: inherit;
			}

			input[type="color"] {
				padding: 0.25rem;
				height: 48px;
			}

			input[type="range"] {
				width: 100%;
			}

			input[type="file"] {
				cursor: pointer;
			}

			input[type="file"]::file-selector-button {
				border: 0;
				border-radius: 8px;
				padding: 0.5rem 0.72rem;
				margin-right: 0.65rem;
				font: inherit;
				font-weight: 800;
				color: #fff;
				background: linear-gradient(130deg, var(--accent), var(--accent-dark));
				cursor: pointer;
				transition: filter 150ms ease, transform 150ms ease;
			}

			input[type="file"]::file-selector-button:hover {
				filter: brightness(1.06);
				transform: translateY(-1px);
			}

			input[type="file"]::-webkit-file-upload-button {
				border: 0;
				border-radius: 8px;
				padding: 0.5rem 0.72rem;
				margin-right: 0.65rem;
				font: inherit;
				font-weight: 800;
				color: #fff;
				background: linear-gradient(130deg, var(--accent), var(--accent-dark));
				cursor: pointer;
				transition: filter 150ms ease, transform 150ms ease;
			}

			button {
				appearance: none;
				border: 0;
				border-radius: 12px;
				padding: 0.85rem 1rem;
				font-family: "Manrope", "Segoe UI", sans-serif;
				font-size: 0.98rem;
				font-weight: 800;
				background: linear-gradient(130deg, var(--accent), var(--accent-dark));
				color: #fff;
				cursor: pointer;
				transform: translateY(0);
				transition: transform 150ms ease, filter 150ms ease;
			}

			button:hover {
				transform: translateY(-1px);
				filter: brightness(1.06);
			}

			button:disabled {
				opacity: 0.6;
				cursor: not-allowed;
				transform: none;
			}

			.action-group {
				display: grid;
				grid-template-columns: repeat(2, minmax(0, 1fr));
				gap: 0.5rem;
			}

			.stage {
				background: var(--panel);
				border-radius: 18px;
				padding: clamp(0.8rem, 1.8vw, 1.2rem);
				box-shadow: var(--shadow);
				display: grid;
				gap: 0.6rem;
			}

			#preview {
				width: 100%;
				height: auto;
				aspect-ratio: 16 / 9;
				border-radius: 12px;
				border: 1px solid rgba(17, 32, 47, 0.18);
				background: #d8d8d8;
			}

			.meta {
				font-size: 0.86rem;
				opacity: 0.82;
			}

			.epic {
				background: var(--panel);
				border-radius: 18px;
				padding: clamp(0.9rem, 2vw, 1.2rem);
				box-shadow: var(--shadow);
				display: grid;
				gap: 0.8rem;
			}

			.epic-title {
				margin: 0;
				font-family: "Bebas Neue", Impact, sans-serif;
				font-size: clamp(1.5rem, 5vw, 2.3rem);
				letter-spacing: 0.03em;
			}

			.epic-copy {
				margin: 0;
				font-size: 0.96rem;
				opacity: 0.9;
			}

			#epicPrompt {
				width: 100%;
				min-height: 140px;
				border: 1px solid #c8baa9;
				border-radius: 10px;
				padding: 0.7rem;
				font: inherit;
				resize: vertical;
				background: #fffdf9;
			}

			.epic-actions {
				display: flex;
				gap: 0.7rem;
				align-items: center;
				flex-wrap: wrap;
			}

			#copyPromptBtn {
				max-width: 220px;
			}

			.fade-in {
				opacity: 0;
				transform: translateY(14px);
				animation: fadeUp 450ms ease forwards;
			}

			.fade-in.delay {
				animation-delay: 120ms;
			}

			@keyframes fadeUp {
				to {
					opacity: 1;
					transform: translateY(0);
				}
			}

			@media (max-width: 640px) {
				.wrapper {
					margin: 1rem auto 1.4rem;
				}

				.controls {
					grid-template-columns: 1fr;
				}
			}
		</style>
	</head>
	<body>
		<Navbar active="generator" />

		<main class="wrapper">
			<header class="fade-in">
				<h1 class="title">Generador de Portadas de Baloncesto 1920 x 1080</h1>
				<p class="subtitle">
					Sube ambos logos, elige color y exporta una imagen final con márgenes simétricos y tamaño visual equivalente.
				</p>
			</header>

			<section class="controls fade-in delay">
				<div class="field">
					<label for="homeLogo">Foto logo equipo local</label>
					<div class="drop-zone" id="homeDropZone">
						<input id="homeLogo" type="file" accept="image/*" />
						<small>Tambien puedes arrastrar y soltar aqui.</small>
					</div>
				</div>
				<div class="field">
					<label for="awayLogo">Foto logo equipo visitante</label>
					<div class="drop-zone" id="awayDropZone">
						<input id="awayLogo" type="file" accept="image/*" />
						<small>Tambien puedes arrastrar y soltar aqui.</small>
					</div>
				</div>
				<div class="field">
					<label for="logoScale">Tamano logos (90%-120%)</label>
					<input id="logoScale" type="range" min="90" max="120" step="1" value="100" />
					<p class="meta" id="logoScaleLabel">Escala actual: 100%</p>
				</div>
				<div class="field">
					<label for="swapTeamsBtn">Atajos</label>
					<button id="swapTeamsBtn" type="button">Intercambiar local/visitante</button>
				</div>
				<div class="field">
					<label for="bgColor">Color del fondo</label>
					<input id="bgColor" type="color" value="#67bfff" />
				</div>
				<div class="field">
					<label for="bgStyle">Estilo de fondo</label>
					<select id="bgStyle">
						<option value="gradient">Gradiente suave</option>
						<option value="stripes">Franjas diagonales</option>
						<option value="spotlight">Foco central</option>
						<option value="split">Mitades enfrentadas</option>
						<option value="dots">Patron de puntos</option>
					</select>
				</div>
				<div class="field">
					<label for="downloadPngBtn">Exportar</label>
					<div class="action-group">
						<button id="downloadPngBtn" type="button">Descargar PNG</button>
						<button id="downloadWebpBtn" type="button">Descargar WEBP</button>
					</div>
				</div>
			</section>

			<section class="stage fade-in delay">
				<canvas id="preview" width="960" height="540"></canvas>
				<p class="meta" id="status">Estado: esperando logos.</p>
			</section>

			<section class="epic fade-in delay">
				<h2 class="epic-title">Quieres hacerlo mas epico?</h2>
				<p class="epic-copy">
					Dile a la IA lo siguiente subiendole la foto que has descargado + jugador y disfruta.
				</p>
				<textarea id="epicPrompt">
Crea una imagen promocional ultra epica de baloncesto con estilo cinematografico.
Usa como referencia principal la portada adjunta del partido y combina la identidad visual de ambos equipos.
Incluye al jugador adjunto como MVP absoluto de la jornada, en primer plano, con presencia dominante, energia y dramatismo.
Iluminacion de pabellon nocturno, humo atmosferico, chispas de luz, contraste alto, detalles hiperrealistas y color grading de pelicula deportiva.
Mantener el escudo y colores de los equipos coherentes con la portada base.
Composicion vertical potente para redes sociales, nitidez alta, calidad profesional, sin texto adicional.
				</textarea>
				<div class="epic-actions">
					<button id="copyPromptBtn" type="button">Copiar prompt</button>
					<p class="meta" id="copyPromptStatus">Puedes editar el prompt antes de copiarlo.</p>
				</div>
			</section>
		</main>
		<Footer />

		<script>
			// @ts-nocheck
			const homeInput = document.getElementById("homeLogo");
			const awayInput = document.getElementById("awayLogo");
			const homeDropZone = document.getElementById("homeDropZone");
			const awayDropZone = document.getElementById("awayDropZone");
			const logoScaleInput = document.getElementById("logoScale");
			const logoScaleLabel = document.getElementById("logoScaleLabel");
			const swapTeamsBtn = document.getElementById("swapTeamsBtn");
			const colorInput = document.getElementById("bgColor");
			const bgStyleInput = document.getElementById("bgStyle");
			const downloadPngBtn = document.getElementById("downloadPngBtn");
			const downloadWebpBtn = document.getElementById("downloadWebpBtn");
			const previewCanvas = document.getElementById("preview");
			const statusText = document.getElementById("status");
			const epicPrompt = document.getElementById("epicPrompt");
			const copyPromptBtn = document.getElementById("copyPromptBtn");
			const copyPromptStatus = document.getElementById("copyPromptStatus");

			const state = {
				home: null,
				away: null,
				bg: colorInput.value,
				bgStyle: bgStyleInput.value,
				logoScale: Number(logoScaleInput.value),
			};

			function hexToRgb(hex) {
				const value = hex.replace("#", "");
				const normalized =
					value.length === 3
						? value
								.split("")
								.map((c) => c + c)
								.join("")
						: value;
				const num = Number.parseInt(normalized, 16);
				return {
					r: (num >> 16) & 255,
					g: (num >> 8) & 255,
					b: num & 255,
				};
			}

			function rgbToCss({ r, g, b }) {
				return `rgb(${r}, ${g}, ${b})`;
			}

			function shadeColor(hex, factor) {
				const rgb = hexToRgb(hex);
				const shade = (channel) => Math.max(0, Math.min(255, Math.round(channel * factor)));
				return rgbToCss({ r: shade(rgb.r), g: shade(rgb.g), b: shade(rgb.b) });
			}

			function loadImage(file) {
				if (!file) return Promise.resolve(null);
				return new Promise((resolve, reject) => {
					const url = URL.createObjectURL(file);
					const img = new Image();
					img.onload = () => {
						URL.revokeObjectURL(url);
						resolve(img);
					};
					img.onerror = (error) => {
						URL.revokeObjectURL(url);
						reject(error);
					};
					img.src = url;
				});
			}

			function drawContain(ctx, img, box) {
				const ratio = Math.min(box.w / img.width, box.h / img.height);
				const drawW = img.width * ratio;
				const drawH = img.height * ratio;
				const x = box.x + (box.w - drawW) / 2;
				const y = box.y + (box.h - drawH) / 2;
				ctx.drawImage(img, x, y, drawW, drawH);
			}

			function drawPlaceholder(ctx, box, text) {
				ctx.save();
				ctx.fillStyle = "rgba(255,255,255,0.9)";
				ctx.textAlign = "center";
				ctx.textBaseline = "middle";
				ctx.font = `${Math.round(box.h * 0.11)}px Manrope`;
				ctx.shadowColor = "rgba(0,0,0,0.22)";
				ctx.shadowBlur = box.h * 0.05;
				ctx.fillText(text, box.x + box.w / 2, box.y + box.h / 2);
				ctx.restore();
			}

			function drawBackground(ctx, w, h, renderState) {
				if (renderState.bgStyle === "stripes") {
					ctx.fillStyle = shadeColor(renderState.bg, 0.78);
					ctx.fillRect(0, 0, w, h);
					ctx.save();
					ctx.translate(-w * 0.2, 0);
					ctx.rotate((-14 * Math.PI) / 180);
					for (let i = 0; i < 16; i += 1) {
						ctx.fillStyle = i % 2 === 0 ? "rgba(255,255,255,0.18)" : "rgba(0,0,0,0.12)";
						ctx.fillRect((w / 10) * i, -h * 0.4, w * 0.06, h * 2);
					}
					ctx.restore();
					return;
				}

				if (renderState.bgStyle === "spotlight") {
					const base = ctx.createLinearGradient(0, 0, w, h);
					base.addColorStop(0, shadeColor(renderState.bg, 0.56));
					base.addColorStop(1, shadeColor(renderState.bg, 0.85));
					ctx.fillStyle = base;
					ctx.fillRect(0, 0, w, h);

					const glow = ctx.createRadialGradient(w * 0.5, h * 0.5, h * 0.08, w * 0.5, h * 0.5, h * 0.65);
					glow.addColorStop(0, "rgba(255,255,255,0.35)");
					glow.addColorStop(1, "rgba(255,255,255,0)");
					ctx.fillStyle = glow;
					ctx.fillRect(0, 0, w, h);
					return;
				}

				if (renderState.bgStyle === "split") {
					ctx.fillStyle = shadeColor(renderState.bg, 0.65);
					ctx.fillRect(0, 0, w / 2, h);
					ctx.fillStyle = shadeColor(renderState.bg, 1.1);
					ctx.fillRect(w / 2, 0, w / 2, h);
					ctx.fillStyle = "rgba(255,255,255,0.12)";
					ctx.fillRect(w * 0.49, 0, w * 0.02, h);
					return;
				}

				if (renderState.bgStyle === "dots") {
					ctx.fillStyle = shadeColor(renderState.bg, 0.72);
					ctx.fillRect(0, 0, w, h);
					ctx.save();
					ctx.fillStyle = "rgba(255,255,255,0.15)";
					const step = Math.round(w * 0.04);
					for (let y = step / 2; y < h; y += step) {
						for (let x = step / 2; x < w; x += step) {
							ctx.beginPath();
							ctx.arc(x, y, Math.max(1.5, w * 0.003), 0, Math.PI * 2);
							ctx.fill();
						}
					}
					ctx.restore();
					return;
				}

				const gradient = ctx.createLinearGradient(0, 0, w, h);
				gradient.addColorStop(0, shadeColor(renderState.bg, 1.28));
				gradient.addColorStop(0.45, shadeColor(renderState.bg, 0.92));
				gradient.addColorStop(1, shadeColor(renderState.bg, 0.58));
				ctx.fillStyle = gradient;
				ctx.fillRect(0, 0, w, h);
			}

			function renderScene(canvas, renderState) {
				const ctx = canvas.getContext("2d");
				const w = canvas.width;
				const h = canvas.height;

				ctx.clearRect(0, 0, w, h);
				drawBackground(ctx, w, h, renderState);

				const marginX = w * 0.04;
				const boxSize = h * 0.62 * (renderState.logoScale / 100);
				const boxY = (h - boxSize) / 2;
				const leftBox = { x: marginX, y: boxY, w: boxSize, h: boxSize };
				const rightBox = { x: w - marginX - boxSize, y: boxY, w: boxSize, h: boxSize };

				if (renderState.home) {
					drawContain(ctx, renderState.home, leftBox);
				} else {
					drawPlaceholder(ctx, leftBox, "LOGO LOCAL");
				}

				if (renderState.away) {
					drawContain(ctx, renderState.away, rightBox);
				} else {
					drawPlaceholder(ctx, rightBox, "LOGO VISITANTE");
				}

				ctx.save();
				ctx.textAlign = "center";
				ctx.textBaseline = "middle";
				ctx.font = `${Math.round(h * 0.14)}px Bebas Neue`;
				ctx.fillStyle = "rgba(255,255,255,0.95)";
				ctx.shadowColor = "rgba(0,0,0,0.25)";
				ctx.shadowBlur = h * 0.03;
				ctx.fillText("VS", w / 2, h / 2);
				ctx.restore();
			}

			function setExportButtonsState(isBusy, label) {
				downloadPngBtn.disabled = isBusy;
				downloadWebpBtn.disabled = isBusy;
				if (isBusy) {
					downloadPngBtn.textContent = label;
					downloadWebpBtn.textContent = label;
					return;
				}
				downloadPngBtn.textContent = "Descargar PNG";
				downloadWebpBtn.textContent = "Descargar WEBP";
			}

			function updateStatus() {
				const localReady = !!state.home;
				const awayReady = !!state.away;
				if (localReady && awayReady) {
					statusText.textContent = "Estado: todo listo para exportar en 1920x1080.";
					return;
				}
				if (localReady || awayReady) {
					statusText.textContent = "Estado: falta subir uno de los dos logos.";
					return;
				}
				statusText.textContent = "Estado: esperando logos.";
			}

			function repaintPreview() {
				renderScene(previewCanvas, state);
				logoScaleLabel.textContent = `Escala actual: ${state.logoScale}%`;
				updateStatus();
			}

			async function handleLogoFile(side, file) {
				if (!file) return;
				if (!file.type.startsWith("image/")) {
					window.alert("Solo se permiten imagenes para los logos.");
					return;
				}
				const image = await loadImage(file);
				state[side] = image;
				repaintPreview();
			}

			function setupDropZone(zone, side) {
				zone.addEventListener("dragover", (event) => {
					event.preventDefault();
					zone.classList.add("drag-over");
				});

				zone.addEventListener("dragleave", () => {
					zone.classList.remove("drag-over");
				});

				zone.addEventListener("drop", async (event) => {
					event.preventDefault();
					zone.classList.remove("drag-over");
					const [file] = event.dataTransfer.files;
					await handleLogoFile(side, file);
				});
			}

			homeInput.addEventListener("change", async (event) => {
				const [file] = event.target.files;
				await handleLogoFile("home", file);
			});

			awayInput.addEventListener("change", async (event) => {
				const [file] = event.target.files;
				await handleLogoFile("away", file);
			});

			setupDropZone(homeDropZone, "home");
			setupDropZone(awayDropZone, "away");

			logoScaleInput.addEventListener("input", (event) => {
				state.logoScale = Number(event.target.value);
				repaintPreview();
			});

			swapTeamsBtn.addEventListener("click", () => {
				const currentHome = state.home;
				state.home = state.away;
				state.away = currentHome;
				repaintPreview();
			});

			colorInput.addEventListener("input", (event) => {
				state.bg = event.target.value;
				repaintPreview();
			});

			bgStyleInput.addEventListener("change", (event) => {
				state.bgStyle = event.target.value;
				repaintPreview();
			});

			function downloadImage(format) {
				if (!state.home || !state.away) {
					window.alert("Debes subir ambos logos antes de generar la imagen.");
					return;
				}

				setExportButtonsState(true, "Generando...");

				const exportCanvas = document.createElement("canvas");
				exportCanvas.width = 1920;
				exportCanvas.height = 1080;
				renderScene(exportCanvas, state);
				const mimeType = format === "webp" ? "image/webp" : "image/png";

				exportCanvas.toBlob((blob) => {
					if (!blob) {
						window.alert("No se pudo crear la imagen.");
						setExportButtonsState(false, "");
						return;
					}

					const link = document.createElement("a");
					const now = new Date();
					const stamp = `${now.getFullYear()}${String(now.getMonth() + 1).padStart(2, "0")}${String(now.getDate()).padStart(2, "0")}-${String(now.getHours()).padStart(2, "0")}${String(now.getMinutes()).padStart(2, "0")}${String(now.getSeconds()).padStart(2, "0")}`;
					link.download = `portada-${stamp}.${format}`;
					link.href = URL.createObjectURL(blob);
					link.click();
					URL.revokeObjectURL(link.href);

					setExportButtonsState(false, "");
				}, mimeType, 0.95);
			}

			downloadPngBtn.addEventListener("click", () => {
				downloadImage("png");
			});

			downloadWebpBtn.addEventListener("click", () => {
				downloadImage("webp");
			});

			copyPromptBtn.addEventListener("click", async () => {
				try {
					await navigator.clipboard.writeText(epicPrompt.value.trim());
					copyPromptStatus.textContent = "Prompt copiado. Pegalo en tu IA junto a portada + foto del jugador.";
				} catch {
					copyPromptStatus.textContent = "No se pudo copiar automaticamente. Copialo manualmente desde el cuadro.";
				}
			});

			repaintPreview();
		</script>
	</body>
</html>
