---
const { active = "generator" } = Astro.props;
const generatorActive = active === "generator";
const cropActive = active === "crop";
const xtoxActive = active === "xtox";
---

<nav class="navbar" aria-label="Navegacion principal">
	<div class="brand">
		<span class="brand-mark">
			<img src="/generadorjornadas.png" alt="Logo Generador Jornadas" loading="eager" decoding="async" />
		</span>
		<div>
			<p class="brand-title">
				<span>Generador de Jornadas for</span>
				<a class="brand-pill" href="https://junstats.vercel.app" target="_blank" rel="noopener noreferrer">JunStats</a>
			</p>
			<p class="brand-subtitle">Baloncesto</p>
		</div>
	</div>

	<div class="links">
		<a href="/1920x1080" aria-current={generatorActive ? "page" : undefined} class={generatorActive ? "link active" : "link"}>
			1920x1080
		</a>
		<a href="/recortar" aria-current={cropActive ? "page" : undefined} class={cropActive ? "link active" : "link"}>
			Recortar
		</a>
		<a href="/xtox" aria-current={xtoxActive ? "page" : undefined} class={xtoxActive ? "link active" : "link"}>
			X to X
		</a>
	</div>
</nav>

<style>
	.navbar {
		width: min(1150px, 92vw);
		margin: 1rem auto 0;
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: 1rem;
		padding: 0.95rem 1rem;
		border-radius: 18px;
		background: rgba(255, 255, 255, 0.82);
		box-shadow: 0 14px 35px rgba(9, 25, 36, 0.16);
		backdrop-filter: blur(4px);
	}

	.brand {
		display: flex;
		align-items: center;
		gap: 0.85rem;
	}

	.brand-mark {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		width: 2.7rem;
		height: 2.7rem;
		overflow: hidden;
		border-radius: 12px;
		filter: drop-shadow(0 4px 8px rgba(20, 56, 91, 0.28));
	}

	.brand-mark img {
		width: 100%;
		height: 100%;
		display: block;
		object-fit: cover;
	}

	.brand-title,
	.brand-subtitle {
		margin: 0;
		line-height: 1.05;
	}

	.brand-title {
		font-weight: 800;
		display: flex;
		align-items: center;
		gap: 0.35rem;
		flex-wrap: wrap;
	}

	.brand-pill {
		padding: 0.18rem 0.5rem;
		border-radius: 999px;
		border: 1px solid rgba(31, 92, 179, 0.25);
		background: rgba(103, 191, 255, 0.14);
		color: #1f5cb3;
		font-weight: 800;
		font-size: 0.9rem;
		text-decoration: none;
		transition: background 140ms ease, transform 140ms ease;
	}

	.brand-pill:hover {
		background: rgba(103, 191, 255, 0.26);
		transform: translateY(-1px);
	}

	.brand-subtitle {
		font-size: 0.84rem;
		opacity: 0.72;
	}

	.links {
		display: inline-flex;
		gap: 0.5rem;
		flex-wrap: wrap;
	}

	.link {
		text-decoration: none;
		padding: 0.7rem 0.95rem;
		border-radius: 999px;
		font-weight: 800;
		color: #11202f;
		background: rgba(255, 255, 255, 0.7);
		border: 1px solid rgba(17, 32, 47, 0.12);
		transition: transform 150ms ease, background 150ms ease, color 150ms ease;
	}

	.link:hover {
		transform: translateY(-1px);
		background: rgba(103, 191, 255, 0.18);
	}

	.link.active {
		background: linear-gradient(130deg, #67bfff, #2a78d4);
		color: #fff;
		border-color: transparent;
	}

	@media (max-width: 640px) {
		.navbar {
			flex-direction: column;
			align-items: stretch;
		}

		.links {
			justify-content: stretch;
	}

		.link {
			text-align: center;
		}
	}
</style>
